<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
    <Product Id="*" Name="Cloak CLI" Language="1033"  Version="$(var.Version)" Manufacturer="Cloak" UpgradeCode="A1B2C3D4-E5F6-4A5B-8C7D-9E0F1A2B3C4D">
        <Package InstallerVersion="200" Compressed="yes" InstallScope="perMachine" />

        <MajorUpgrade DowngradeErrorMessage="There is already a newer version of Cloak installed." />
        <MediaTemplate EmbedCab="yes" />

        <Feature Id="ProductFeature" Title="Cloak" Level="1">
            <ComponentGroupRef Id="ProductComponents" />
        </Feature>
    </Product>

    <Fragment>
        <Directory Id="TARGETDIR" Name="SourceDir">
            <Directory Id="ProgramFilesFolder">
                <Directory Id="INSTALLFOLDER" Name="Cloak" />
            </Directory>
        </Directory>
    </Fragment>

    <Fragment>
        <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">
            <Component Id="CloakExe" Guid="12345678-90AB-CDEF-1234-567890ABCDEF">
                <File Id="CloakExecutable" Source="cloak.exe" KeyPath="yes" />
                
                <Environment Id="UPDATEPATH" Name="PATH" Value="[INSTALLFOLDER]" Permanent="no" Part="last" Action="set" System="yes" />
            </Component>
        </ComponentGroup>
    </Fragment>
</Wix>